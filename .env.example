# Copie para .env (na VPS) e preencha com os valores reais.
# As duas NEXT_PUBLIC_* são públicas (vão para o navegador). A service role é SECRETA.

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# --- Traefik / domínio (deploy na VPS) ---
# Domínio público do CRM (aponte no Cloudflare para o IP da VPS)
CRM_DOMAIN=crm.seudominio.com.br
# Nome do certresolver configurado no seu Traefik (ex.: letsencrypt, le, cloudflare)
TRAEFIK_CERTRESOLVER=letsencrypt
